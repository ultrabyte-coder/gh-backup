# Конфиг gh-backup — скопируйте как .env и заполните своими данными
# cp .env.example .env

# GitHub username (буквы, цифры, дефисы; макс. 39 символов)
GH_USERNAME='your-github-username'

# Personal Access Token (ghp_, gho_, ghu_, ghs_ или github_pat_)
# Создать: https://github.com/settings/tokens
# Разрешения: repo, gist, read:org
GH_TOKEN='ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'

# Директория для хранения бэкапов (по умолчанию: backups)
BACKUP_DIR='backups'
